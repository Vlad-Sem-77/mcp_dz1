# Скопируй этот файл в .env и заполни своими значениями.
# .env НЕ попадает в git (он в .gitignore).
# В Replit вставляй значения через Secrets (не в файл .env напрямую).

# Обязательно:
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Опционально — модель по умолчанию (бесплатные варианты OpenRouter):
# google/gemini-2.0-flash-exp:free      <- рекомендуется (хорошо работает с tool calling)
# meta-llama/llama-3.3-70b-instruct:free
# mistralai/mistral-7b-instruct:free
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# Flask
FLASK_SECRET_KEY=change-me-to-something-random
PORT=5000
